# Odin Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
ODIN_PREFIX=!
ODIN_LOG_LEVEL=INFO

# Database
ODIN_DATABASE_URL=postgresql+asyncpg://odin:password@localhost:5432/odin

# Web Dashboard
ODIN_WEB_PORT=8080
ODIN_WEB_SECRET=change_this_to_a_random_secret

# Discord OAuth2 (for dashboard login)
ODIN_OAUTH_CLIENT_ID=your_client_id
ODIN_OAUTH_CLIENT_SECRET=your_client_secret
ODIN_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
